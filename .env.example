# ============================================
# Aegis — Environment Variables (CONFIGURED)
# ============================================

# ── Mistral AI API Key (Engineer agent — patch generation)
MISTRAL_API_KEY=

# ── Groq API Key (Finder + Exploiter agents — ultra-fast inference)
GROQ_API_KEY=
# ── GitHub Personal Access Token
GITHUB_TOKEN=

# ── GitHub OAuth ───────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Webhook Secret ──────────────────────────────────────
GITHUB_WEBHOOK_SECRET=

# ── Token Encryption ────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── Local App URLs ──────────────────────────────────────
FRONTEND_URL=
BACKEND_URL=

# ── Model Configuration
HACKER_MODEL=codestral-2508
ENGINEER_MODEL=devstral-2512

# ── Server
PORT=8000

# ── Notifications (optional) ────────────────────────────
# Slack incoming webhook URL — leave empty to disable
SLACK_WEBHOOK_URL=
# Discord webhook URL — leave empty to disable
DISCORD_WEBHOOK_URL=

# ── Demo Mode ─────────────────────────────────────────────
# Set to true to bypass the Docker sandbox and simulate a successful exploit/test
DEMO_MODE=true
