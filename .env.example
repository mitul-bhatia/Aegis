# ============================================
# Aegis — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Anthropic API Key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# GitHub Personal Access Token — https://github.com/settings/tokens
# Required permissions: repo, pull_requests, webhooks
GITHUB_TOKEN=ghp_your-token-here

# Webhook Secret — any random string you make up
# Must match exactly what you paste into GitHub webhook settings
GITHUB_WEBHOOK_SECRET=your-random-secret-string

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-20250514

# Server port
PORT=8000
