# ============================================
# Aegis — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Mistral AI API Key ──────────────────────────────────────
# Sign up at https://console.mistral.ai/
# Go to: API Keys → Create New Key
# Pricing: Devstral 2 = $0.40/$2.00 per 1M tokens
#          Codestral  = $0.20/$0.60 per 1M tokens
MISTRAL_API_KEY=your-mistral-api-key-here

# ── GitHub Personal Access Token ────────────────────────────
# Go to: https://github.com/settings/tokens
# Required permissions: repo (full control of private repos)
GITHUB_TOKEN=ghp_your-token-here

# ── Webhook Secret ──────────────────────────────────────────
# Any random string you make up.
# Must match exactly what you paste into GitHub webhook settings.
# Generate one: python -c "import secrets; print(secrets.token_hex(16))"
GITHUB_WEBHOOK_SECRET=your-random-secret-string

# ── GitHub OAuth (frontend sign-in flow) ───────────────────
# Create an OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=Ov23li7vdknIS2ZtxxOH
GITHUB_CLIENT_SECRET=0a7a157122949acf0c24f21ca38b148db8e12108

# Frontend/backend URLs used for CORS and webhook setup
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── Model Configuration ────────────────────────────────────
# Hacker Agent (Agent A) — writes exploits to prove vulnerabilities
# Using Codestral: fast, cheap, code-focused, minimal guardrails
HACKER_MODEL=codestral-2508

# Engineer Agent (Agent B) — writes security patches
# Using Devstral 2: frontier agentic coding model, best at multi-file fixes
ENGINEER_MODEL=devstral-2512

# ── Server ──────────────────────────────────────────────────
PORT=8000

# ── Semgrep Scanner (optional overrides) ───────────────────
# If semgrep is not on PATH, set an absolute binary path here.
# Example: /Users/you/project/.venv/bin/semgrep
SEMGREP_BIN=

# If local semgrep is unavailable/broken, scanner falls back to Docker.
SEMGREP_DOCKER_IMAGE=returntocorp/semgrep:latest

# Max seconds allowed for semgrep scan invocation.
SEMGREP_TIMEOUT=180
